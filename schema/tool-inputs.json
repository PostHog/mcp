                            "regex",
                            "not_regex",
                            "is_cleaned_path_exact",
                            "exact",
                            "is_not",
                            "gt",
                            "gte",
                            "lt",
                            "lte",
                            "min",
                            "max",
                            "exact",
                            "is_not",
                            "in",
                            "not_in"
                          ]
                        }
                      },
                      "required": [
                        "key",
                        "value"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "rollout_percentage": {
                    "type": "number"
                  }
                },
                "required": [
                  "properties",
                  "rollout_percentage"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "groups"
          ],
          "additionalProperties": false
        },
        "active": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "key",
        "description",
        "filters",
        "active"
